# Server
PORT=5000
NODE_ENV=development

# MongoDB
MONGO_URI=mongodb://localhost:27017/feedmind

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=7d

# Google OAuth (optional)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Gemini AI
GEMINI_API_KEY=your_gemini_api_key

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173
# Optional: comma-separated list of extra allowed origins
# FRONTEND_URLS=http://localhost:5173,https://your-tunnel-url.inc1.devtunnels.ms

# Hugging Face
HF_TOKEN=your_hugging_face_access_token_here
